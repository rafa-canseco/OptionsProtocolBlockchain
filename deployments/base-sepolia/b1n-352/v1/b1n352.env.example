# Network and signer. Never commit a populated PRIVATE_KEY.
BASE_SEPOLIA_RPC_URL=
PRIVATE_KEY=

# The only static deployment-input binding accepted by Base Sepolia scripts.
# Contracts, policy, roles, V1 baselines, owners, and expected build hashes are read directly from this JSON.
FUND_APPROVED_INPUTS_PATH=
FUND_APPROVED_INPUTS_SHA256=

# Runtime receipt from ScheduleB1N352Activation. It is deliberately not a static approved input.
FUND_SCHEDULED_ALLOCATION_PAUSE_NONCE=

# Populate only from deployment simulation/broadcast output for later phases and reconciliation.
FUND_FACTORY=
FUND_ACCESS_MANAGER_DEPLOYER=
FUND_ACCESS_MANAGER_DEPLOYER_CODEHASH=
FUND_ACCESS_MANAGER=
FUND_VAULT_PROXY=
FUND_SHARE_PROXY=
FUND_ACCOUNTING_PROXY=
FUND_FLOW_MANAGER_PROXY=
FUND_STRATEGY_MANAGER_PROXY=
FUND_CSP_ADAPTER_PROXY=
FUND_CSP_VALUATOR=
FUND_IN_KIND_STRATEGY_ESCROW=
FUND_EMERGENCY_STRATEGY_ESCROW=
FUND_VAULT_IMPLEMENTATION=
FUND_SHARE_IMPLEMENTATION=
FUND_ACCOUNTING_IMPLEMENTATION=
FUND_FLOW_MANAGER_IMPLEMENTATION=
FUND_STRATEGY_MANAGER_IMPLEMENTATION=
FUND_CSP_ADAPTER_IMPLEMENTATION=
FUND_DEPLOYMENT_ID=
FUND_NAV_REPORT_VERIFIER=
FUND_NAV_REPORT_VERIFIER_CODEHASH=
FUND_CLAIM_ESCROW=
FUND_CLAIM_ESCROW_CODEHASH=
FUND_ACCESS_MANAGER_CODEHASH=

# Used only by ReconcileB1N352IntermediateDeployment. Final reconciliation always requires both true.
FUND_EXPECT_ADAPTER_ONBOARDED=false
FUND_EXPECT_STRATEGY_ACTIVE=false
